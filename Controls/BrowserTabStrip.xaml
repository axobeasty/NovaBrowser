<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="NovaBrowser.Controls.BrowserTabStrip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="StripRoot" SizeChanged="OnStripSizeChanged">
        <Border
            VerticalAlignment="Bottom"
            BorderBrush="{StaticResource NovaTabStripDividerBrush}"
            BorderThickness="0,0,0,1" />

        <Grid
            Margin="12,0,0,0"
            Padding="0,6,0,0"
            VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="142" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Padding="0,0,8,0" VerticalAlignment="Bottom">
                <StackPanel
                    x:Name="TabHost"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal"
                    Spacing="2" />

                <Border
                    x:Name="InsertIndicator"
                    Width="2"
                    Height="28"
                    Margin="0,0,0,4"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource NovaAccentBrush}"
                    Visibility="Collapsed" />
            </Grid>

            <Button
                x:Name="AddTabButton"
                Grid.Column="1"
                Width="28"
                Height="28"
                Margin="0,0,8,4"
                VerticalAlignment="Bottom"
                Click="OnAddTabClick"
                Style="{StaticResource NovaTabAddButtonStyle}">
                <FontIcon x:Name="AddTabIcon" FontSize="10" Glyph="&#xE710;" />
            </Button>
        </Grid>
    </Grid>
</UserControl>
