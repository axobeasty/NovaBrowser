<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="NovaBrowser.Controls.SidePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource NovaContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Spacing="4" Padding="8">
            <Button x:Name="BookmarksTabButton" Click="OnBookmarksTabClick" Content="Bookmarks" />
            <Button x:Name="HistoryTabButton" Click="OnHistoryTabClick" Content="History" />
            <Button x:Name="DownloadsTabButton" Click="OnDownloadsTabClick" Content="Downloads" />
            <Button x:Name="ScriptsTabButton" Click="OnScriptsTabClick" Content="Scripts" />
        </StackPanel>
        <ListView x:Name="ItemsList" Grid.Row="1" SelectionChanged="OnItemSelected" />
    </Grid>
</UserControl>
