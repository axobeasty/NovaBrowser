<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="NovaBrowser.Controls.SettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NovaBrowser.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="PanelRoot" Background="{StaticResource NovaContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="HeaderGrid"
            Grid.Row="0"
            Padding="24,20,24,16"
            Background="{StaticResource NovaToolbarBackgroundBrush}"
            BorderBrush="{StaticResource NovaTabStripDividerBrush}"
            BorderThickness="0,0,0,1">
            <TextBlock
                x:Name="HeaderTitleText"
                FontSize="22"
                FontWeight="SemiBold"
                Foreground="{StaticResource NovaTextPrimaryBrush}"
                Text="Настройки" />

            <Button
                x:Name="CloseButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Click="OnCloseClick"
                Style="{StaticResource SubtleButtonStyle}"
                ToolTipService.ToolTip="Закрыть">
                <FontIcon Glyph="&#xE711;" FontSize="12" />
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="NavigationColumn"
                Background="{StaticResource NovaToolbarBackgroundBrush}"
                BorderBrush="{StaticResource NovaTabStripDividerBrush}"
                BorderThickness="0,0,1,0">
                <ListView
                    x:Name="SectionList"
                    Padding="12,16"
                    SelectionChanged="OnSectionChanged">
                    <ListViewItem x:Name="GeneralNavItem" Tag="general" />
                    <ListViewItem x:Name="PrivacyNavItem" Tag="privacy" />
                    <ListViewItem x:Name="DataNavItem" Tag="data" />
                    <ListViewItem x:Name="ProfilesNavItem" Tag="profiles" />
                    <ListViewItem x:Name="ToolsNavItem" Tag="tools" />
                    <ListViewItem x:Name="AppearanceNavItem" Tag="appearance" />
                    <ListViewItem x:Name="AboutNavItem" Tag="about" />
                </ListView>
            </Border>

            <Grid x:Name="ContentColumn" Grid.Column="1">
                <ScrollViewer x:Name="GeneralSection" Padding="24,20">
                    <StackPanel Spacing="20" MaxWidth="640">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="LanguageLabelText" FontWeight="SemiBold" Text="Язык" />
                            <ComboBox x:Name="LanguageComboBox" HorizontalAlignment="Stretch" DisplayMemberPath="Title" SelectionChanged="OnLanguageSelectionChanged" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="HomePageLabelText" FontWeight="SemiBold" Text="Домашняя страница" />
                            <TextBox x:Name="HomePageBox" PlaceholderText="https://www.bing.com" TextChanged="OnHomePageChanged" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="SearchEngineLabelText" FontWeight="SemiBold" Text="Поисковая система" />
                            <ComboBox x:Name="SearchEngineComboBox" HorizontalAlignment="Stretch" DisplayMemberPath="Title" SelectionChanged="OnSearchEngineSelectionChanged" />
                        </StackPanel>
                        <StackPanel x:Name="CustomSearchEnginePanel" Spacing="8" Visibility="Collapsed">
                            <TextBlock x:Name="CustomSearchEngineLabelText" FontWeight="SemiBold" Text="Свой URL поиска" />
                            <TextBox x:Name="CustomSearchEngineBox" PlaceholderText="https://example.com/search?q=" TextChanged="OnCustomSearchEngineChanged" />
                            <TextBlock x:Name="CustomSearchEngineHintText" Foreground="{StaticResource NovaTextSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="SessionRestoreLabelText" FontWeight="SemiBold" Text="При запуске" />
                            <ComboBox x:Name="SessionRestoreComboBox" HorizontalAlignment="Stretch" SelectionChanged="OnSessionRestoreChanged" />
                        </StackPanel>
                        <ToggleSwitch x:Name="BookmarkBarToggle" Toggled="OnBookmarkBarToggled" />
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="PrivacySection" Padding="24,20" Visibility="Collapsed">
                    <StackPanel Spacing="20" MaxWidth="640">
                        <ToggleSwitch x:Name="AdBlockToggle" Toggled="OnAdBlockToggled" />
                        <ToggleSwitch x:Name="TelemetryToggle" Toggled="OnTelemetryToggled" />
                        <TextBlock x:Name="PrivacyHintText" Foreground="{StaticResource NovaTextSecondaryBrush}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ClearHistoryButton" Click="OnClearHistoryClick" />
                            <Button x:Name="ClearDownloadsButton" Click="OnClearDownloadsClick" />
                            <Button x:Name="ClearAllDataButton" Click="OnClearDataClick" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="DataSection" Padding="24,20" Visibility="Collapsed">
                    <StackPanel Spacing="20" MaxWidth="640">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="DownloadDirectoryLabelText" FontWeight="SemiBold" Text="Папка загрузок" />
                            <TextBox x:Name="DownloadDirectoryBox" TextChanged="OnDownloadDirectoryChanged" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ImportChromeButton" Click="OnImportChromeClick" />
                            <Button x:Name="ImportEdgeButton" Click="OnImportEdgeClick" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ExportSyncButton" Click="OnExportSyncClick" />
                            <Button x:Name="ImportSyncButton" Click="OnImportSyncClick" />
                        </StackPanel>
                        <Button x:Name="DefaultBrowserButton" Click="OnDefaultBrowserClick" HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="ProfilesSection" Padding="24,20" Visibility="Collapsed">
                    <StackPanel Spacing="20" MaxWidth="640">
                        <TextBlock x:Name="ProfilesHintText" Foreground="{StaticResource NovaTextSecondaryBrush}" TextWrapping="Wrap" />
                        <ComboBox x:Name="ProfilesComboBox" HorizontalAlignment="Stretch" DisplayMemberPath="Name" SelectionChanged="OnProfileChanged" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox x:Name="NewProfileNameBox" Width="240" PlaceholderText="Profile name" />
                            <Button x:Name="CreateProfileButton" Click="OnCreateProfileClick" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="ToolsSection" Padding="24,20" Visibility="Collapsed">
                    <StackPanel Spacing="12" MaxWidth="640">
                        <TextBlock x:Name="ToolsHintText" Foreground="{StaticResource NovaTextSecondaryBrush}" TextWrapping="Wrap" />
                        <Button x:Name="OpenBookmarksWindowButton" Click="OnOpenBookmarksWindowClick" HorizontalAlignment="Stretch" />
                        <Button x:Name="OpenHistoryWindowButton" Click="OnOpenHistoryWindowClick" HorizontalAlignment="Stretch" />
                        <Button x:Name="OpenDownloadsWindowButton" Click="OnOpenDownloadsWindowClick" HorizontalAlignment="Stretch" />
                        <Button x:Name="OpenScriptsWindowButton" Click="OnOpenScriptsWindowClick" HorizontalAlignment="Stretch" />
                        <Button x:Name="OpenPasswordsWindowButton" Click="OnOpenPasswordsWindowClick" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="AppearanceSection" Visibility="Collapsed">
                    <controls:ThemeSettingsPanel x:Name="ThemePanel" />
                </Grid>

                <ScrollViewer x:Name="AboutSection" Padding="24,20" Visibility="Collapsed">
                    <StackPanel Spacing="16" MaxWidth="640">
                        <TextBlock x:Name="AboutDescriptionText" Foreground="{StaticResource NovaTextSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBlock x:Name="AboutVersionText" FontWeight="SemiBold" Foreground="{StaticResource NovaTextPrimaryBrush}" />
                        <Button x:Name="CheckUpdatesButton" Click="OnCheckUpdatesClick" HorizontalAlignment="Left" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Grid
            x:Name="FooterGrid"
            Grid.Row="2"
            Padding="24,12,24,20"
            Background="{StaticResource NovaToolbarBackgroundBrush}"
            BorderBrush="{StaticResource NovaTabStripDividerBrush}"
            BorderThickness="0,1,0,0"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="CancelButton" Grid.Column="1" Click="OnCancelClick" Style="{StaticResource SubtleButtonStyle}" />
            <Button x:Name="ApplyButton" Grid.Column="2" Click="OnApplyClick" Style="{StaticResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</UserControl>
