<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="NovaBrowser.Controls.ThemeSettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:NovaBrowser.ViewModels"
    mc:Ignorable="d">

    <Grid x:Name="PanelRoot" Background="{StaticResource NovaContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="HeaderGrid"
            Grid.Row="0"
            Padding="24,20,24,16"
            Background="{StaticResource NovaToolbarBackgroundBrush}"
            BorderBrush="{StaticResource NovaTabStripDividerBrush}"
            BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="Темы и оформление" />
                <TextBlock
                    Opacity="0.65"
                    Text="Светлая и тёмная темы из коробки. Настройте цвета и сохраняйте свои пресеты."
                    TextWrapping="Wrap" />
            </StackPanel>

            <Button
                Grid.Column="1"
                VerticalAlignment="Top"
                Click="OnCloseClick"
                Style="{StaticResource SubtleButtonStyle}"
                ToolTipService.ToolTip="Закрыть">
                <FontIcon Glyph="&#xE711;" FontSize="12" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="24,16">
            <StackPanel Spacing="20">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="Режим темы" />
                    <ComboBox
                        x:Name="ModeComboBox"
                        HorizontalAlignment="Stretch"
                        DisplayMemberPath="Title"
                        SelectionChanged="OnModeSelectionChanged" />
                </StackPanel>

                <StackPanel
                    x:Name="CustomThemePickerPanel"
                    Spacing="8"
                    Visibility="Collapsed">
                    <TextBlock FontWeight="SemiBold" Text="Сохранённые темы" />
                    <ComboBox
                        x:Name="CustomThemeComboBox"
                        HorizontalAlignment="Stretch"
                        DisplayMemberPath="Name"
                        SelectionChanged="OnCustomThemeSelectionChanged" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="Имя темы" />
                    <TextBox
                        x:Name="ThemeNameBox"
                        PlaceholderText="Моя тема"
                        TextChanged="OnThemeNameChanged" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="OnLoadLightClick" Content="Светлая" Style="{StaticResource SubtleButtonStyle}" />
                    <Button Click="OnLoadDarkClick" Content="Тёмная" Style="{StaticResource SubtleButtonStyle}" />
                    <Button Click="OnSaveCustomClick" Content="Сохранить как свою" Style="{StaticResource AccentButtonStyle}" />
                    <Button
                        x:Name="DeleteThemeButton"
                        Click="OnDeleteCustomClick"
                        Content="Удалить"
                        Style="{StaticResource SubtleButtonStyle}"
                        Visibility="Collapsed" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Конструктор цветов" />
                    <TextBlock
                        Opacity="0.6"
                        Text="Изменения сразу видны в браузере. Чтобы сохранить — «Сохранить как свою»."
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel x:Name="ColorGroupsHost" Spacing="16" />
            </StackPanel>
        </ScrollViewer>

        <Grid
            x:Name="FooterGrid"
            Grid.Row="2"
            Padding="24,12,24,20"
            Background="{StaticResource NovaToolbarBackgroundBrush}"
            BorderBrush="{StaticResource NovaTabStripDividerBrush}"
            BorderThickness="0,1,0,0"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="1"
                Click="OnCancelClick"
                Content="Отмена"
                Style="{StaticResource SubtleButtonStyle}" />

            <Button
                Grid.Column="2"
                Click="OnApplyClick"
                Content="Применить"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</UserControl>
