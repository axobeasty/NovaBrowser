<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="NovaBrowser.Controls.BrowserTabItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        x:Name="TabRoot"
        Padding="10,0,6,0"
        VerticalAlignment="Bottom"
        Background="{StaticResource NovaTabInactiveBackgroundBrush}"
        BorderBrush="{StaticResource NovaTabBorderBrush}"
        BorderThickness="1"
        CornerRadius="10,10,10,10"
        PointerEntered="OnPointerEntered"
        PointerExited="OnPointerExited"
        PointerPressed="OnPointerPressed"
        RightTapped="OnRightTapped"
        Tapped="OnTapped">
        <Grid Height="32" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="AccentBar"
                Height="2"
                Margin="-10,0,-6,0"
                VerticalAlignment="Top"
                Background="{StaticResource NovaAccentBrush}"
                CornerRadius="2,2,0,0"
                Opacity="0"
                Translation="0,-1,0" />

            <Grid
                Grid.Column="0"
                Width="16"
                Height="16"
                VerticalAlignment="Center">
                <ProgressRing
                    x:Name="LoadingRing"
                    Width="14"
                    Height="14"
                    IsActive="False"
                    Visibility="Collapsed" />
                <FontIcon
                    x:Name="SiteIcon"
                    FontSize="11"
                    Glyph="&#xE774;"
                    Opacity="0.85" />
                <Image
                    x:Name="FaviconImage"
                    Width="14"
                    Height="14"
                    Visibility="Collapsed" />
            </Grid>

            <TextBlock
                x:Name="TitleText"
                Grid.Column="1"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="Normal"
                Opacity="0.78"
                TextTrimming="CharacterEllipsis" />

            <Button
                x:Name="CloseButton"
                Grid.Column="2"
                Width="24"
                Height="24"
                Padding="0"
                VerticalAlignment="Center"
                Click="OnCloseClick"
                Style="{StaticResource NovaTabCloseButtonStyle}"
                Visibility="Collapsed">
                <FontIcon FontSize="8" Glyph="&#xE711;" />
            </Button>
        </Grid>
    </Border>
</UserControl>
