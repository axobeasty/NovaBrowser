<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="NovaBrowser.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NovaBrowser">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="NovaAccentBrush" Color="#6C5CE7" />
            <SolidColorBrush x:Key="NovaAccentSecondaryBrush" Color="#A29BFE" />

            <SolidColorBrush x:Key="NovaTabActiveBackgroundBrush" Color="#2A2D3A" />
            <SolidColorBrush x:Key="NovaTabInactiveBackgroundBrush" Color="#1A1D28" />
            <SolidColorBrush x:Key="NovaTabBorderBrush" Color="#33FFFFFF" />
            <SolidColorBrush x:Key="NovaTabAddHoverBrush" Color="#33FFFFFF" />

            <Style x:Key="NovaTabCloseButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="UseSystemFocusVisuals" Value="False" />
            </Style>

            <Style x:Key="NovaTabAddButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="{StaticResource NovaTabBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="UseSystemFocusVisuals" Value="False" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
