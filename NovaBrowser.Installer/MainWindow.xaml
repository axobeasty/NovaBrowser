<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="NovaBrowser.Installer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="NovaBrowser Setup">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="16" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Width="52"
                Height="52"
                CornerRadius="14"
                Background="{StaticResource NovaAccentBrush}">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="N" />
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                <TextBlock
                    x:Name="HeaderTitle"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Text="NovaBrowser Setup" />
                <TextBlock
                    x:Name="HeaderSubtitle"
                    Opacity="0.7"
                    Text="Установка браузера на WinUI 3" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Padding="28"
            Background="{StaticResource NovaCardBrush}"
            BorderBrush="{StaticResource NovaCardBorderBrush}"
            BorderThickness="1"
            CornerRadius="16">
            <Grid x:Name="StepHost" />
        </Border>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                x:Name="FooterHint"
                VerticalAlignment="Center"
                Opacity="0.55"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Шаг 1 из 3" />

            <Button
                x:Name="BackButton"
                Grid.Column="1"
                Margin="0,0,8,0"
                Click="OnBackClick"
                Content="Назад"
                Style="{StaticResource NovaSecondaryButtonStyle}"
                Visibility="Collapsed" />

            <Button
                x:Name="NextButton"
                Grid.Column="2"
                Click="OnNextClick"
                Content="Далее"
                Style="{StaticResource NovaPrimaryButtonStyle}" />
        </Grid>
    </Grid>
</Window>
