<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NovaBrowser.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NovaBrowser.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Padding="12,8"
            ColumnSpacing="8"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                Spacing="4">
                <Button
                    AutomationProperties.Name="Назад"
                    Command="{x:Bind ViewModel.GoBackCommand}"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="Назад">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
                <Button
                    AutomationProperties.Name="Вперёд"
                    Command="{x:Bind ViewModel.GoForwardCommand}"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="Вперёд">
                    <FontIcon Glyph="&#xE72A;" FontSize="14" />
                </Button>
                <Button
                    AutomationProperties.Name="Обновить"
                    Command="{x:Bind ViewModel.ReloadCommand}"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="Обновить">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>
                <Button
                    AutomationProperties.Name="Домой"
                    Command="{x:Bind ViewModel.GoHomeCommand}"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="Домашняя страница">
                    <FontIcon Glyph="&#xE80F;" FontSize="14" />
                </Button>
            </StackPanel>

            <Grid Grid.Column="1" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="AddressBar"
                    Grid.Column="0"
                    PlaceholderText="Введите адрес или поисковый запрос"
                    Text="{x:Bind ViewModel.ActiveAddressBarText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    KeyDown="OnAddressBarKeyDown"
                    CornerRadius="20"
                    Padding="16,8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" />

                <Button
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.NavigateCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    CornerRadius="20"
                    Padding="16,8"
                    Content="Перейти" />
            </Grid>
        </Grid>

        <Grid x:Name="TabContentHost" Grid.Row="1" />
    </Grid>
</Page>
