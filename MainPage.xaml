<?xml version="1.0" encoding="utf-8" ?>

<Page

    x:Class="NovaBrowser.MainPage"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:controls="using:NovaBrowser.Controls"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    mc:Ignorable="d">



    <Grid x:Name="PageRoot" RowSpacing="0" Background="{StaticResource NovaContentBackgroundBrush}">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto" />

            <RowDefinition Height="*" />

        </Grid.RowDefinitions>



        <Grid
            x:Name="ToolbarGrid"
            Grid.Row="0"

            Padding="12,8"

            ColumnSpacing="8"

            Background="{StaticResource NovaToolbarBackgroundBrush}"

            BorderBrush="{StaticResource NovaTabStripDividerBrush}"

            BorderThickness="0,0,0,1">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="Auto" />

                <ColumnDefinition Width="*" />

                <ColumnDefinition Width="Auto" />

            </Grid.ColumnDefinitions>



            <StackPanel

                Grid.Column="0"

                Orientation="Horizontal"

                Spacing="4">

                <Button
                    x:Name="NavBackButton"
                    AutomationProperties.Name="Назад"

                    Command="{x:Bind ViewModel.GoBackCommand}"

                    Style="{StaticResource SubtleButtonStyle}"

                    ToolTipService.ToolTip="Назад">

                    <FontIcon Glyph="&#xE72B;" FontSize="14" />

                </Button>

                <Button
                    x:Name="NavForwardButton"
                    AutomationProperties.Name="Вперёд"

                    Command="{x:Bind ViewModel.GoForwardCommand}"

                    Style="{StaticResource SubtleButtonStyle}"

                    ToolTipService.ToolTip="Вперёд">

                    <FontIcon Glyph="&#xE72A;" FontSize="14" />

                </Button>

                <Button
                    x:Name="NavReloadButton"
                    AutomationProperties.Name="Обновить"

                    Command="{x:Bind ViewModel.ReloadCommand}"

                    Style="{StaticResource SubtleButtonStyle}"

                    ToolTipService.ToolTip="Обновить">

                    <FontIcon Glyph="&#xE72C;" FontSize="14" />

                </Button>

                <Button
                    x:Name="NavHomeButton"
                    AutomationProperties.Name="Домой"

                    Command="{x:Bind ViewModel.GoHomeCommand}"

                    Style="{StaticResource SubtleButtonStyle}"

                    ToolTipService.ToolTip="Домашняя страница">

                    <FontIcon Glyph="&#xE80F;" FontSize="14" />

                </Button>

            </StackPanel>



            <TextBox
                x:Name="AddressBar"
                Grid.Column="1"
                PlaceholderText="Введите адрес или поисковый запрос"
                Text="{x:Bind ViewModel.ActiveAddressBarText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                KeyDown="OnAddressBarKeyDown"
                CornerRadius="20"
                Padding="16,8"
                BorderThickness="1"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" />



            <StackPanel

                Grid.Column="2"

                VerticalAlignment="Center"

                Orientation="Horizontal"

                Spacing="8">

                <TextBlock
                    x:Name="VersionLabel"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource NovaTextSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind AppVersionLabel, Mode=OneTime}" />

                <Button
                    x:Name="SettingsButton"
                    AutomationProperties.Name="Настройки"

                    Click="OnSettingsClick"

                    Style="{StaticResource SubtleButtonStyle}"

                    ToolTipService.ToolTip="Настройки">

                    <FontIcon Glyph="&#xE713;" FontSize="14" />

                </Button>

                <Button
                    x:Name="UpdatesButton"
                    AutomationProperties.Name="Проверить обновления"

                    Click="OnCheckUpdatesClick"

                    Style="{StaticResource SubtleButtonStyle}"

                    ToolTipService.ToolTip="Проверить обновления">

                    <Grid Width="14" Height="14">
                        <FontIcon Glyph="&#xE895;" FontSize="14" />

                        <Ellipse
                            x:Name="UpdateBadge"
                            Width="7"
                            Height="7"
                            Margin="0,-1,-1,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Fill="{StaticResource NovaAccentBrush}"
                            IsHitTestVisible="False"
                            Visibility="Collapsed" />
                    </Grid>

                </Button>

            </StackPanel>

        </Grid>



        <Grid x:Name="TabContentHost" Grid.Row="1" Background="{StaticResource NovaContentBackgroundBrush}" />



        <Grid

            x:Name="SettingsOverlay"

            Grid.RowSpan="2"

            Background="#99000000"

            Visibility="Collapsed">

            <controls:SettingsPanel

                x:Name="SettingsPanel"

                MaxWidth="980"

                Margin="24"

                HorizontalAlignment="Stretch"

                VerticalAlignment="Stretch" />

        </Grid>

    </Grid>

</Page>


